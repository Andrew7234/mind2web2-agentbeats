{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/rdi-foundation/mind2web2-agentbeats:latest",
    entrypoint: ["uv", "run", "src/server.py", "--host", "0.0.0.0", "--port", "8081"],
    env: {
      // We'll receive participant URLs over A2A, but we need to include the
      // slot URL somewhere in the program in order for Amber to allow us to
      // connect. Here we're putting it in an unused environment variable.
      AMBER_HINT_PROXY: "${slots.proxy}",
      OPENAI_API_KEY: "${config.openai_api_key}",
      GEMINI_API_KEY: "${config.gemini_api_key}",
      DEEPSEEK_API_KEY: "${config.deepseek_api_key}",
      AGENT_LLM: "${config.judge_llm}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8081 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      judge_llm: { type: "string", default: "openai/gpt-4o-mini" },
      openai_api_key: { type: "string", secret: true, default: "" },
      gemini_api_key: { type: "string", secret: true, default: "" },
      deepseek_api_key: { type: "string", secret: true, default: "" },
    },
    required: [],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a", optional: true },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: { a2a: "a2a" },
  metadata: {
    assessment_config: {
      domain: "dev_set",
    },
    participant_roles: ["agent"],
  },
}
